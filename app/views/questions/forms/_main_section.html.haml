.question-form__main
  .form-field
    = form.label :topic_id, 'Topic'
    = form.collection_select :topic_id, @topics_for_form, :id, :name,
      { prompt: 'Select a topic' },
      class: 'question-form__select',
      data: { question_form_target: 'topicSelect', action: 'change->question-form#topicChanged' }

  .form-field
    %label Learning outcomes
    %span.hint Link the outcomes assessed by this question (type to search).
    - @topics_for_form.each do |topic|
      - groups = topic.learning_objectives.group_by(&:category)
      .lo-topic-group{ data: { question_form_target: 'group', topic_id: topic.id } }
        - if groups.present?
          .lo-dropdown{ data: { question_form_target: 'dropdown' } }
            .lo-dropdown__trigger{ data: { action: 'click->question-form#toggleDropdown' } }
              %input.lo-dropdown__input{ type: 'text', placeholder: 'Type to search or click to browse...', data: { question_form_target: 'loSearch', action: 'input->question-form#filterLos click->question-form#openDropdown' }, autocomplete: 'off' }
              .lo-dropdown__selected{ data: { question_form_target: 'selectedCount' } } 0 selected
            .lo-dropdown__menu{ data: { question_form_target: 'dropdownMenu' } }
              - groups.sort_by { |cat, _| cat }.each do |category, objectives|
                .lo-category
                  .lo-category__title= category
                  .lo-category__items
                    - objectives.sort_by(&:position).each do |objective|
                      %label.lo-item{ data: { lo_id: objective.id, lo_text: objective.description.downcase } }
                        %input.lo-item__checkbox{ type: 'checkbox', name: 'question[learning_objective_ids][]', value: objective.id, checked: selected_ids.include?(objective.id), data: { action: 'change->question-form#updateCount' } }
                        %span.lo-item__text= truncate(objective.description, length: 120)
        - else
          %p.lo-empty No learning outcomes for this topic yet.

  .form-row
    .form-field
      = form.label :question_type, 'Question type'
      = form.select :question_type, Question::QUESTION_TYPES.map { |t| [t.humanize, t] }, {},
        class: 'question-form__select',
        data: { question_form_target: 'typeSelect', action: 'change->question-form#typeChanged' }
    .form-field
      = form.label :points, 'Points'
      = form.number_field :points, min: 1, class: 'question-form__input'
  .form-field
    = form.label :answer_size, 'Answer space'
    = form.select :answer_size, [['Auto', nil], ['Short', 'short'], ['Medium', 'medium'], ['Long', 'long']],
      {}, class: 'question-form__select'

  .form-field
    = form.label :content, 'Question prompt'
    = form.text_area :content, rows: 6, class: 'question-form__textarea', required: true

  .form-field
    = form.label :answer, 'Model answer'
    %span.hint Provide the official solution or marking guidance. Required for every question type.
    = form.text_area :answer, rows: 5, class: 'question-form__textarea', required: true
