- options = question.options.is_a?(Hash) ? question.options : {}
.type-panel-content{ data: {
  controller: 'diagram-label-builder',
  'diagram-label-builder-field-id-value': options_field_id,
  'diagram-label-builder-options-value': options.to_json,
  action: 'question-type:activated->diagram-label-builder#activate'
} }
  %p.hint Specify the diagram image and the labels to reveal.
  %label
    %span.hint Image URL
    %input.question-form__input{ type: 'text', placeholder: 'https://example.com/image.png', data: { 'diagram-label-builder-target': 'image', action: 'input->diagram-label-builder#changed' } }
  %label
    %span.hint Labels (one per line)
    %textarea.question-form__textarea{ rows: 6, data: { 'diagram-label-builder-target': 'labels', action: 'input->diagram-label-builder#changed' } }
