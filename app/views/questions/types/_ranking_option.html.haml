- idx_string = index.to_s
- label_text = idx_string =~ /^\d+$/ ? "Option #{idx_string.to_i + 1}" : 'New option'
- name_base = "question[ranking_options][#{idx_string}]"
- text_value = option[:text].to_s
- rank_value = option[:rank].to_i.positive? ? option[:rank].to_i : (idx_string =~ /^\d+$/ ? idx_string.to_i + 1 : 1)
.ranking-option-row{ data: { index: idx_string } }
  .ranking-option-body
    %label.hint{ for: "ranking-option-#{idx_string}" }= label_text
    %textarea.ranking-option-textarea{ id: "ranking-option-#{idx_string}", name: "#{name_base}[text]", rows: 3,
      placeholder: 'Write the option text', data: { action: 'input->ranking-builder#updateOption' } }= text_value
  .ranking-option-controls
    %label
      %span.hint Correct ranking
      %input.ranking-option-rank-input{ type: 'number', min: 1, name: "#{name_base}[rank]", value: rank_value,
        data: { action: 'input->ranking-builder#updateOption' } }
    %button.ranking-option-remove{ type: 'button', data: { action: 'ranking-builder#removeOption', index: idx_string } } Remove
