<%#
  Workspace shell — `layouts/workspace.html.erb` just yields body;
  the sidebar + main grid live here (shared with application.html.erb
  via `shared/_sidebar`). `@tab` selects the tab partial.
%>
<div class="app" data-controller="<%= 'autosave' if @exam %>"
     data-autosave-exam-id-value="<%= @exam&.id %>"
     data-autosave-debounce-value="3000">

  <%= render 'shared/sidebar', active_tab: @tab %>

  <main class="main">
    <%= render "workspaces/tab_#{@tab}", tab: @tab %>
  </main>
</div>
