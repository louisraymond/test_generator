<% tabs = [
  ['dashboard', 'Dashboard',      'Activity & quick actions'],
  ['setup',     'Setup',          'Spec the exam'],
  ['kb',        'Knowledge base', 'Topics, objectives, resources'],
  ['canvas',    'Canvas',         'Edit the paper'],
  ['review',    'Review',         'Preview & export']
] %>

<header class="meta-nav"
        data-controller="<%= 'autosave' if @exam %>"
        data-autosave-exam-id-value="<%= @exam&.id %>"
        data-autosave-debounce-value="3000">
  <div class="meta-nav__brand">
    <a class="meta-nav__wordmark" href="<%= root_path %>">ExamGen</a>
    <span class="meta-nav__tag">v0.9 · alpha</span>
  </div>

  <nav class="meta-tabs" aria-label="Workspace tabs">
    <% tabs.each do |id, label, _hint| %>
      <%= link_to label,
                  workspace_path(tab: id, exam: params[:exam]),
                  class: ['meta-tabs__btn', ('is-active' if @tab == id)].compact.join(' '),
                  'aria-current': (@tab == id ? 'page' : nil) %>
    <% end %>
  </nav>

  <details class="meta-new">
    <summary class="meta-new__btn" aria-label="Create new">+ New</summary>
    <div class="meta-new__panel">
      <div class="meta-new__section">Content</div>
      <%= link_to 'New question',  new_question_path,      class: 'meta-new__item' %>
      <%= link_to 'Question bank', questions_path,         class: 'meta-new__item' %>
      <%= link_to 'Topics',        topics_path,            class: 'meta-new__item' %>
      <div class="meta-new__section">Exam</div>
      <%= link_to 'New exam',      new_exam_path,          class: 'meta-new__item' %>
      <%= link_to 'New template',  new_exam_template_path, class: 'meta-new__item' %>
      <%= link_to 'Template list', exam_templates_path,    class: 'meta-new__item' %>
    </div>
  </details>

  <span class="meta-nav__state" data-meta-autosave data-state="idle">Idle</span>
  <%= link_to 'Classic →', exams_path(ui: 'classic'),
              style: 'margin-left:12px; font-size:12px; color:#6b6358; font-family:var(--mono); text-decoration:none;' %>
  <% if @exam %>
    <span hidden data-exam-lock-version="<%= @exam.lock_version %>"></span>
  <% end %>
</header>

<main class="workspace-shell__main">
  <%= render "workspaces/tab_#{@tab}", tab: @tab %>
</main>
