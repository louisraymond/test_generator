<% if @exam %>
  <section class="canvas" data-controller="canvas" data-canvas-exam-id-value="<%= @exam.id %>">
    <%# Left: question list %>
    <aside class="canvas__qlist" aria-label="Question list">
      <header class="qlist__header">
        <div class="eyebrow">Questions</div>
        <div class="qlist__title"><%= @exam.title %></div>
      </header>
      <ol class="qlist" role="list">
        <% @exam.exam_questions.each_with_index do |eq, i| %>
          <% q = eq.question %>
          <%= link_to rail_exam_question_path(eq),
                      class: 'qlist-item',
                      data: { eq_id: eq.id, action: 'click->canvas#selectQuestion', 'turbo-frame': 'rail-body' } do %>
            <span class="drag-handle" aria-hidden="true">⋮⋮</span>
            <span class="qlist-item__num"><%= i + 1 %></span>
            <span class="qlist-item__type"><%= q.question_type %></span>
            <span class="qlist-item__stem"><%= truncate(strip_tags(q.content.to_s), length: 48) %></span>
            <span class="qlist-item__marks"><%= q.points %>m</span>
          <% end %>
        <% end %>
      </ol>
    </aside>

    <%# Centre: live paper preview (Turbo Frame reloads on edit) %>
    <main class="canvas__preview">
      <div class="canvas__preview-inner">
        <turbo-frame id="paper-preview" src="<%= preview_frame_exam_path(@exam) %>" data-canvas-target="frame">
          <p class="canvas__preview-loading">Loading preview…</p>
        </turbo-frame>
      </div>
    </main>

    <%# Right: inspector rail (Phase 6 wires it, Phase 7 fills per-type) %>
    <aside class="canvas__rail" data-canvas-target="rail">
      <turbo-frame id="rail-body">
        <header class="rail__header">
          <div class="eyebrow">Inspector</div>
          <div class="rail__hint">Select a question on the left</div>
        </header>
      </turbo-frame>
    </aside>
  </section>
<% else %>
  <section class="tab-stub" data-tab="canvas">
    <div class="tab-stub__eyebrow">Canvas</div>
    <h1 class="tab-stub__title">No exam selected</h1>
    <p class="tab-stub__body">
      Open this tab with <code>?exam=ID</code> to start editing a paper.
      Pick an exam from the <%= link_to 'Exam History', exams_path %> list.
    </p>
  </section>
<% end %>
