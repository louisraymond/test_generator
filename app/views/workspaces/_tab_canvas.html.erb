<% if @exam %>
  <section class="canvas" data-controller="canvas" data-canvas-exam-id-value="<%= @exam.id %>">
    <%# Left: question list %>
    <aside class="canvas__qlist" aria-label="Question list">
      <header class="qlist__header">
        <div class="eyebrow">Questions</div>
        <div class="qlist__title"><%= @exam.title %></div>
        <div class="qlist__actions">
          <%= link_to '+ New question', new_question_path, class: 'qlist__action' %>
          <%= link_to 'Bank →', questions_path, class: 'qlist__action' %>
        </div>
      </header>
      <ol class="qlist" role="list">
        <% @exam.exam_questions.each_with_index do |eq, i| %>
          <% q = eq.question %>
          <li class="qlist-row">
            <%= link_to rail_exam_question_path(eq),
                        class: 'qlist-item',
                        data: { eq_id: eq.id, action: 'click->canvas#selectQuestion', 'turbo-frame': 'rail-body' } do %>
              <span class="drag-handle" aria-hidden="true">⋮⋮</span>
              <span class="qlist-item__num"><%= i + 1 %></span>
              <span class="qlist-item__type"><%= q.question_type %></span>
              <span class="qlist-item__stem"><%= truncate(strip_tags(q.content.to_s), length: 40) %></span>
              <span class="qlist-item__marks"><%= q.points %>m</span>
            <% end %>
            <%= link_to '✎', edit_question_path(q), target: '_blank',
                        class: 'qlist-item__edit', title: 'Open full editor' %>
          </li>
        <% end %>
      </ol>
    </aside>

    <%# Centre: live paper preview (Turbo Frame reloads on edit) %>
    <main class="canvas__preview">
      <div class="canvas__preview-inner">
        <turbo-frame id="paper-preview" src="<%= preview_frame_exam_path(@exam) %>" data-canvas-target="frame">
          <p class="canvas__preview-loading">Loading preview…</p>
        </turbo-frame>
      </div>
    </main>

    <%# Right: inspector rail (Phase 6 wires it, Phase 7 fills per-type) %>
    <aside class="canvas__rail" data-canvas-target="rail">
      <turbo-frame id="rail-body">
        <header class="rail__header">
          <div class="eyebrow">Inspector</div>
          <div class="rail__hint">Select a question on the left</div>
        </header>
      </turbo-frame>
    </aside>
  </section>
<% else %>
  <section class="workspace-picker">
    <header>
      <div class="eyebrow">Canvas · pick an exam to edit</div>
      <h1>Open a paper</h1>
    </header>

    <% if @recent_exams.any? %>
      <ul class="picker-list">
        <% @recent_exams.each do |e| %>
          <li class="picker-row">
            <div class="picker-row__meta">
              <div class="picker-row__title"><%= e.title %></div>
              <div class="picker-row__sub">
                <%= e.exam_questions.size %> questions
                <% if e.exam_template %> · <%= e.exam_template.name %><% end %>
                · <%= e.created_at.to_date.strftime('%-d %b %Y') %>
              </div>
            </div>
            <div class="picker-row__actions">
              <%= link_to 'Open in Canvas', workspace_path(tab: 'canvas', exam: e.id), class: 'primary-btn' %>
              <%= link_to 'Preview', paper_exam_path(e), class: 'ghost-btn', target: '_blank' %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="picker-empty">No exams yet. <%= link_to 'Create one', new_exam_path %>.</p>
    <% end %>

    <footer class="workspace-picker__footer">
      <%= link_to '+ New exam (classic form)', new_exam_path, class: 'ghost-btn' %>
      <%= link_to 'Question bank', questions_path, class: 'ghost-btn' %>
      <%= link_to 'New question', new_question_path, class: 'ghost-btn' %>
    </footer>
  </section>
<% end %>
