<div class="section-card" data-template-form-target="sectionCard">
  <div class="section-card__header">
    <h3 class="section-card__title">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
      Section
    </h3>
    <button type="button" class="btn btn--small btn--danger" data-action="click->template-form#removeSection">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
      Remove
    </button>
  </div>

  <%= form.hidden_field :_destroy %>
  <%= form.hidden_field :position %>

  <div class="section-card__row">
    <div class="section-card__field">
      <%= form.label :name, "Section Name", class: "section-card__label" %>
      <%= form.text_field :name, class: "section-card__input", placeholder: "e.g., Section A: Multiple Choice" %>
    </div>

    <div class="section-card__field section-card__field--small">
      <%= form.label :question_count, "Questions", class: "section-card__label" %>
      <%= form.number_field :question_count, class: "section-card__input", min: 1 %>
    </div>

    <div class="section-card__field section-card__field--small">
      <%= form.label :duration_minutes, "Duration (min)", class: "section-card__label" %>
      <%= form.number_field :duration_minutes, class: "section-card__input", placeholder: "Optional" %>
    </div>
  </div>

  <div class="section-card__row">
    <div class="section-card__field section-card__field--small">
      <%= form.label :min_points, "Min Points", class: "section-card__label" %>
      <%= form.number_field :min_points, class: "section-card__input", placeholder: "Optional" %>
    </div>

    <div class="section-card__field section-card__field--small">
      <%= form.label :max_points, "Max Points", class: "section-card__label" %>
      <%= form.number_field :max_points, class: "section-card__input", placeholder: "Optional" %>
    </div>

    <div class="section-card__field">
      <%= form.label :question_type_filter, "Question Types (leave blank for all)", class: "section-card__label" %>
      <%= form.select :question_type_filter, options_for_select(question_types, form.object.question_types), 
          { include_blank: false }, 
          { multiple: true, class: "section-card__select" } %>
    </div>
  </div>

  <div class="section-card__subsection">
    <h4 class="section-card__subtitle">Source Rules (where to pull questions from)</h4>
    <div class="source-rules">
      <%= form.fields_for :section_source_rules do |source_form| %>
        <%= render 'source_rule_fields', form: source_form, topics: topics %>
      <% end %>
    </div>
    <button type="button" class="btn btn--small btn--secondary" data-action="click->template-form#addSourceRule" data-section-index="<%= form.index %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      Add Source Rule
    </button>
  </div>

  <details class="section-card__details">
    <summary class="section-card__summary">Advanced: Force Include/Exclude Questions</summary>
    <div class="section-card__subsection">
      <h4 class="section-card__subtitle">Question Rules</h4>
      <div class="question-rules">
        <%= form.fields_for :section_question_rules do |question_form| %>
          <%= render 'question_rule_fields', form: question_form, questions: questions %>
        <% end %>
      </div>
      <button type="button" class="btn btn--small btn--secondary" data-action="click->template-form#addQuestionRule" data-section-index="<%= form.index %>">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Add Question Rule
      </button>
    </div>
  </details>
</div>

