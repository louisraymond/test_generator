<div class="rule-field" data-template-form-target="sourceRuleField">
  <%= form.hidden_field :_destroy %>
  
  <div class="rule-field__row">
    <div class="rule-field__select-group">
      <%= form.label :source_type, "Type", class: "rule-field__label" %>
      <%= form.select :source_type, 
          options_for_select([['Topic', 'Topic'], ['Module', 'TopicModule'], ['Learning Objective', 'LearningObjective']], form.object.source_type),
          { include_blank: 'Select type' },
          { class: "rule-field__select", data: { action: "change->template-form#updateSourceOptions" } } %>
    </div>

    <div class="rule-field__select-group">
      <%= form.label :source_id, "Source", class: "rule-field__label" %>
      <%= form.select :source_id, 
          build_source_options(topics, form.object.source_type, form.object.source_id),
          { include_blank: 'Select source' },
          { class: "rule-field__select" } %>
    </div>

    <div class="rule-field__input-group">
      <%= form.label :weight, "Weight", class: "rule-field__label" %>
      <%= form.number_field :weight, class: "rule-field__input", min: 1, value: form.object.weight || 1 %>
    </div>

    <div class="rule-field__input-group">
      <%= form.label :question_count_override, "Exact Count", class: "rule-field__label" %>
      <%= form.number_field :question_count_override, class: "rule-field__input", min: 0, placeholder: "Optional" %>
    </div>

    <button type="button" class="btn btn--small btn--danger rule-field__remove" data-action="click->template-form#removeSourceRule">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
</div>

