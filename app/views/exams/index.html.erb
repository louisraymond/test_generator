<h1>Exam History</h1>
<p class="library-lead">Browse all created exams and their marking schemes. Up to 200 results are shown at a time.</p>

<div class="library-grid">
  <div class="filter-card card">
    <div class="filter-summary">
      <span class="chip">Total exams: <strong><%= @exams.count %></strong></span>
    </div>
  </div>

  <aside class="library-side card">
    <h3>Quick Actions</h3>
    <ul>
      <li><%= link_to 'Generate a new exam →', new_exam_path %></li>
      <li><%= link_to 'Question Bank →', questions_path %></li>
      <li><%= link_to 'Topics →', topics_path %></li>
    </ul>
  </aside>
</div>

<div class="questions-card card">
  <% if @exams.empty? %>
    <p class="muted">No exams created yet. <%= link_to 'Create your first exam', new_exam_path %> to get started!</p>
  <% else %>
    <table class="questions-table">
      <thead>
        <tr>
          <th>Title</th>
          <th>Created</th>
          <th>Duration</th>
          <th>Questions</th>
          <th>Points</th>
          <th>Topics</th>
          <th class="actions">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @exams.each do |exam| %>
          <tr>
            <td>
              <div class="exam-title">
                <strong><%= exam.title %></strong>
              </div>
            </td>
            <td>
              <span class="exam-date">
                <%= exam.created_at.strftime("%d/%m/%Y") %>
              </span>
              <br>
              <span class="muted">
                <%= exam.created_at.strftime("%H:%M") %>
              </span>
            </td>
            <td>
              <% if exam.duration_minutes.present? %>
                <span class="chip"><%= exam.duration_minutes %> min</span>
              <% else %>
                <span class="muted">Not set</span>
              <% end %>
            </td>
            <td class="points">
              <span class="chip"><%= exam.questions.count %></span>
            </td>
            <td class="points">
              <span class="chip"><%= exam.questions.sum(:points) || 0 %></span>
            </td>
            <td class="outcomes">
              <% topics = exam.questions.map(&:topic).uniq %>
              <% if topics.any? %>
                <ul class="outcome-list">
                  <% topics.each do |topic| %>
                    <li><span class="outcome-chip"><%= topic.name %></span></li>
                  <% end %>
                </ul>
              <% else %>
                <span class="muted">None</span>
              <% end %>
            </td>
            <td class="actions-cell">
              <div class="action-buttons">
                <%= link_to 'View', exam_path(exam), class: 'link-edit' %>
                <%= link_to 'Marking Scheme', marking_scheme_exam_path(exam), class: 'link-edit' %>
                <%= link_to 'PDF', exam_path(exam, format: :pdf), class: 'link-edit', target: '_blank' %>
                <%= link_to 'MS PDF', marking_scheme_exam_path(exam, format: :pdf), class: 'link-edit', target: '_blank' %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
