<div class="exam-index">
  <div class="exam-index__header">
    <h1>Exam History</h1>
    <p class="exam-index__subtitle">Browse all created exams and their marking schemes</p>
  </div>

  <% if @exams.any? %>
    <div class="exam-grid">
      <% @exams.each do |exam| %>
        <div class="exam-card">
          <div class="exam-card__header">
            <h2 class="exam-card__title"><%= exam.title %></h2>
            <div class="exam-card__meta">
              <span class="exam-card__date">
                <%= exam.created_at.strftime("%d/%m/%Y at %H:%M") %>
              </span>
              <% if exam.duration_minutes.present? %>
                <span class="exam-card__duration">
                  <%= exam.duration_minutes %> min
                </span>
              <% end %>
            </div>
          </div>

          <div class="exam-card__stats">
            <div class="exam-card__stat">
              <span class="exam-card__stat-label">Questions</span>
              <span class="exam-card__stat-value"><%= exam.questions.count %></span>
            </div>
            <div class="exam-card__stat">
              <span class="exam-card__stat-label">Topics</span>
              <span class="exam-card__stat-value">
                <%= exam.questions.map(&:topic).uniq.count %>
              </span>
            </div>
            <div class="exam-card__stat">
              <span class="exam-card__stat-label">Total Points</span>
              <span class="exam-card__stat-value">
                <%= exam.questions.sum(:points) || 0 %>
              </span>
            </div>
          </div>

          <div class="exam-card__topics">
            <h4>Topics:</h4>
            <div class="exam-card__topic-list">
              <% exam.questions.map(&:topic).uniq.each do |topic| %>
                <span class="exam-card__topic-tag"><%= topic.name %></span>
              <% end %>
            </div>
          </div>

          <div class="exam-card__actions">
            <div class="exam-card__action-group">
              <%= link_to exam_path(exam), class: "exam-card__action exam-card__action--primary" do %>
                <svg class="exam-card__action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14,2 14,8 20,8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10,9 9,9 8,9"></polyline>
                </svg>
                View Exam
              <% end %>
              
              <%= link_to marking_scheme_exam_path(exam), class: "exam-card__action exam-card__action--secondary" do %>
                <svg class="exam-card__action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 11H5a2 2 0 0 0-2 2v3c0 1.1.9 2 2 2h4m0-7v7m0-7h4m-4 0V9a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"></path>
                  <path d="M9 7h6v4H9z"></path>
                </svg>
                Marking Scheme
              <% end %>
            </div>
            
            <div class="exam-card__action-group">
              <%= link_to exam_path(exam, format: :pdf), class: "exam-card__action exam-card__action--tertiary", target: "_blank" do %>
                <svg class="exam-card__action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14,2 14,8 20,8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10,9 9,9 8,9"></polyline>
                </svg>
                Download PDF
              <% end %>
              
              <%= link_to marking_scheme_exam_path(exam, format: :pdf), class: "exam-card__action exam-card__action--tertiary", target: "_blank" do %>
                <svg class="exam-card__action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14,2 14,8 20,8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10,9 9,9 8,9"></polyline>
                </svg>
                Download Marking Scheme PDF
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="exam-index__empty">
      <div class="exam-index__empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14,2 14,8 20,8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
          <polyline points="10,9 9,9 8,9"></polyline>
        </svg>
      </div>
      <h3>No exams created yet</h3>
      <p>Create your first exam to get started!</p>
      <%= link_to "Create New Exam", new_exam_path, class: "exam-index__cta" %>
    </div>
  <% end %>
</div>
