<%#
  Phase 1 — redesigned student paper (used for both PDF rendering and
  HTML preview at /exams/:id/paper). The `layout: 'pdf'` wrapper loads
  fonts.css, tokens.css, and paper.css so the cover and interior
  typography render identically whether snapshotted by Grover or viewed
  in a browser.

  Layout model: one `.paper` block per section (or one single block if the
  exam has no sections). Each `.paper` owns its own running head/foot and
  watermark. CSS `page-break-inside: avoid` on `.q` handles physical
  pagination in print; on-screen, `.paper` grows past 1123px when a section
  is long.
%>

<%= render 'cover_page', exam: @exam %>

<%
  sections_data = @exam.exam_questions.to_a.group_by(&:section_number)
  global_counter = 0
%>

<% sections_data.sort_by { |k, _| k || -1 }.each do |section_number, exam_questions| %>
  <% section = section_number ? @exam.section_info(section_number) : nil %>
  <% section_letter = section&.letter.presence || (section_number ? ('A'.ord + section_number).chr : nil) %>

  <div class="paper">
    <div class="runhead">
      <% if section %>
        <b>Section <%= section_letter %> · <%= section.name %></b>
      <% else %>
        <b><%= (@exam.subject.presence || @exam.title) %></b>
      <% end %>
      <span>Candidate: ________</span>
    </div>

    <% if section %>
      <div class="section-head">
        <div class="section-head__num"><%= section_letter %></div>
        <div class="section-head__title"><%= section.name %></div>
        <div class="section-head__meta">
          <%= pluralize(section.question_count, 'question') %>
          <% if section.duration_minutes %> · ~<%= section.duration_minutes %> min<% end %>
        </div>
      </div>
    <% end %>

    <% exam_questions.each do |eq| %>
      <% global_counter += 1 %>
      <%= render 'paper_question', question: eq.question, counter: global_counter, exam_question: eq %>
    <% end %>

    <div class="wmk">Specimen · do not redistribute</div>
    <div class="runfoot">
      <span>
        <%= [@exam.subject, (@exam.paper_number.present? ? "P#{@exam.paper_number}#{@exam.tier&.first&.upcase}" : nil)].compact.join(' / ').presence || 'Exam' %>
        · <%= (@exam.exam_date || @exam.created_at.to_date).strftime('%d.%m.%Y') %>
      </span>
      <span>
        <% if section %>Section <%= section_letter %><% else %>Interior<% end %>
        · turn over ▶
      </span>
    </div>
  </div>
<% end %>
