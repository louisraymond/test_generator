<%#
  Phase 1 — redesigned student paper (used for both PDF rendering and
  HTML preview at /exams/:id/paper). The `layout: 'pdf'` wrapper loads
  fonts.css, tokens.css, and paper.css so the cover page and interior
  typography render identically whether snapshotted by Grover or viewed
  in a browser.

  Interior question rendering uses the existing
  `questions/types/_<type>.html.haml` partials wrapped in a paper-style
  `.q` grid so the new typography applies without rewriting per-type
  rendering (Phase 7 replaces that wholesale).
%>

<%= render 'cover_page', exam: @exam %>

<% question_counter = 0 %>
<% current_section_number = nil %>
<% @exam.exam_questions.each do |eq| %>
  <% question = eq.question %>
  <% section_number = eq.section_number %>

  <% if @exam.exam_template && section_number && section_number != current_section_number %>
    <% current_section_number = section_number %>
    <% section = @exam.section_info(section_number) %>
    <% if section %>
      <div class="paper">
        <div class="runhead">
          <b>Section <%= section.letter.presence || ('A'.ord + section.position).chr %> · <%= section.name %></b>
          <span>Candidate: ________</span>
        </div>

        <div class="section-head">
          <div class="section-head__num"><%= section.letter.presence || ('A'.ord + section.position).chr %></div>
          <div class="section-head__title"><%= section.name %></div>
          <div class="section-head__meta">
            <%= pluralize(section.question_count, 'question') %>
            <% if section.duration_minutes %> · ~<%= section.duration_minutes %> min<% end %>
          </div>
        </div>

        <div class="wmk">Specimen · do not redistribute</div>
        <div class="runfoot">
          <span>Section <%= section.letter %></span>
          <span>turn over ▶</span>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="paper">
    <div class="runhead">
      <b><%= @exam.subject.presence || @exam.title %></b>
      <span>Q<%= question_counter + 1 %></span>
    </div>

    <div class="q">
      <div class="q__num"><%= question_counter + 1 %></div>
      <div class="q__body">
        <div class="q__stem"><%= question.content.to_s.html_safe %></div>
        <div class="<%= marks_to_workspace(question.points) %>"></div>
        <% if question.points.to_i >= 5 %>
          <%= render_final_answer(label: (question.answer_label.presence || 'Answer') + ' =', unit: question.unit) %>
        <% end %>
      </div>
      <div class="q__marks"><i>[<b><%= question.points %></b> <%= 'mark'.pluralize(question.points) %>]</i></div>
    </div>

    <div class="wmk">Specimen · do not redistribute</div>
    <div class="runfoot">
      <span><%= @exam.subject %></span>
      <span>Page <%= question_counter + 2 %></span>
    </div>
  </div>

  <% question_counter += 1 %>
<% end %>
