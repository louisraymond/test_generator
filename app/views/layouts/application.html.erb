<!DOCTYPE html>
<html>
  <head>
    <title>ExamGenerator</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div data-controller="menu" class="app-shell">
      <header class="app-header">
        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-navigation" data-action="menu#toggle" data-menu-target="toggle">
          <span class="menu-toggle__icon" aria-hidden="true"></span>
          <span class="visually-hidden">Toggle navigation</span>
        </button>

        <%= link_to 'Exam Generator', root_path, class: 'app-logo', data: { action: 'menu#close' } %>
      </header>

      <div class="nav-backdrop" data-menu-target="backdrop" data-action="click->menu#close"></div>

      <nav class="app-nav" id="primary-navigation" data-menu-target="nav">
        <%= nav_link_to 'Exam Generator', root_path %>
        <%= nav_link_to 'Topics', topics_path %>
        <%= nav_link_to 'Question Bank', questions_path %>
      </nav>

      <main class="app-main">
        <%= render 'shared/flash' %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
