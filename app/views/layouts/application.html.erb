<!DOCTYPE html>
<html>
  <head>
    <title>ExamGenerator</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- KaTeX for LaTeX math rendering -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" integrity="sha384-XjKyOOlGwcjNTAIQHIpgOno0Hl1YQqzUOEleOLALmuqehneUG+vnGctmUb0ZY0l8" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js" integrity="sha384-+VBxd3r6XgURycqtZ117nYw44OOcIax56Z4dCRWbxyPt0Koah1uHoK0o4+/RRE05" crossorigin="anonymous"></script>
  </head>

  <body class="<%= params[:ui] == 'classic' ? 'legacy-shell' : 'workspace-shell' %>">
    <% if params[:ui] == 'classic' %>
      <%#
        Classic hamburger chrome — kept one release behind `?ui=classic`
        for anyone who bookmarked the old UI. Retires after Wave 5.
      %>
      <div data-controller="menu" class="app-shell">
        <header class="app-header">
          <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-navigation" data-action="menu#toggle" data-menu-target="toggle">
            <span class="menu-toggle__icon" aria-hidden="true"></span>
            <span class="visually-hidden">Toggle navigation</span>
          </button>
          <%= link_to 'Exam Generator', exams_path, class: 'app-logo', data: { action: 'menu#close' } %>
          <%= link_to 'New workspace →', '/workspace',
                      style: 'margin-left:auto; padding:6px 12px; background:#b4532a; color:white; border-radius:6px; text-decoration:none; font-size:13px; font-weight:500;' %>
        </header>
        <div class="nav-backdrop" data-menu-target="backdrop" data-action="click->menu#close"></div>
        <nav class="app-nav" id="primary-navigation" data-menu-target="nav">
          <%= nav_link_to 'Exam Generator', new_exam_path(ui: 'classic') %>
          <%= nav_link_to 'Exam History', exams_path(ui: 'classic') %>
          <%= nav_link_to 'Exam Templates', exam_templates_path(ui: 'classic') %>
          <%= nav_link_to 'Topics', topics_path(ui: 'classic') %>
          <%= nav_link_to 'Question Bank', questions_path(ui: 'classic') %>
        </nav>
        <main class="app-main">
          <%= render 'shared/flash' %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <%#
        New chrome (Wave 5) — every controller inherits the sidebar shell
        by default. `application.html.erb` is the single place that wraps
        classic `questions`/`topics`/`exams`/`exam_templates` views in the
        design's workspace grid.
      %>
      <div class="app" data-controller="palette">
        <%= render 'shared/sidebar' %>
        <main class="main">
          <%= render 'shared/flash' %>
          <%= yield %>
        </main>
      </div>
    <% end %>
  </body>
</html>
