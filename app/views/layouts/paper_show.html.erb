<!DOCTYPE html>
<html>
  <head>
    <title><%= @exam.title %> · ExamGen</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <style>
      <%= raw File.read(Rails.root.join('app/assets/stylesheets/fonts.css')) %>
      <%= raw File.read(Rails.root.join('app/assets/stylesheets/tokens.css')) %>
      <%= raw File.read(Rails.root.join('app/assets/stylesheets/paper.css')) %>
      <%= raw File.read(Rails.root.join('app/assets/stylesheets/paper_editor.css')) %>
      <%= raw File.read(Rails.root.join('app/assets/stylesheets/exam.css')) %>
      <%= raw File.read(Rails.root.join('app/assets/stylesheets/markdown.css')) %>
      <%= raw File.read(Rails.root.join('app/assets/stylesheets/math_typography.css')) %>

      /* Exam toolbar — ported from the design's #screen-exam .exam-toolbar.
       * Left: title, "Ready to print" status pill, mono meta (questions · time · seed).
       * Right: three action buttons (Marking scheme · Regenerate · Download PDF).
       * Only shown on screen; hidden in print. */
      body { background: var(--paper-2, #efeae0); margin: 0; font-family: var(--sans); color: var(--ink); }
      .exam-toolbar {
        position: sticky; top: 0; z-index: 50;
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 24px;
        background: var(--paper, #f7f4ee);
        border-bottom: 1px solid var(--rule, #d8d0c0);
        gap: 16px;
      }
      .exam-toolbar .l {
        display: flex; align-items: center; gap: 14px; min-width: 0;
      }
      .exam-toolbar .l .title {
        font-family: var(--serif);
        font-weight: 500;
        font-size: 18px;
        letter-spacing: -0.01em;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .exam-toolbar .badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 3px 10px;
        border: 1px solid var(--rule);
        border-radius: 999px;
        font-size: 11px;
        color: var(--ink-3);
        background: var(--paper-2);
      }
      .exam-toolbar .badge .dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--green);
        display: inline-block;
      }
      .exam-toolbar .mono {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-3);
        letter-spacing: 0.02em;
        white-space: nowrap;
      }
      .exam-toolbar .mono b {
        color: var(--ink);
        font-weight: 600;
      }
      .exam-toolbar .r { display: flex; gap: 8px; align-items: center; }
      .exam-toolbar .btn {
        padding: 6px 12px;
        border: 1px solid var(--rule);
        border-radius: 4px;
        background: transparent;
        color: var(--ink);
        font: inherit;
        font-size: 13px;
        text-decoration: none;
        cursor: pointer;
        display: inline-flex; align-items: center; gap: 6px;
      }
      .exam-toolbar .btn:hover { border-color: var(--accent); }
      .exam-toolbar .btn.primary,
      .exam-toolbar .btn.btn--primary {
        background: var(--accent);
        color: var(--paper);
        border-color: var(--accent);
      }
      .exam-toolbar .btn.primary:hover,
      .exam-toolbar .btn.btn--primary:hover { background: var(--accent-ink); }
      @media print { .exam-toolbar { display: none; } }
    </style>

    <!-- KaTeX -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js" crossorigin="anonymous"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        renderMathInElement(document.body, {
          delimiters: [
            {left: '$$', right: '$$', display: true},
            {left: '$', right: '$', display: false},
            {left: '\\(', right: '\\)', display: false},
            {left: '\\[', right: '\\]', display: true}
          ],
          throwOnError: false, strict: false,
          ignoredTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code']
        });
      });
    </script>
  </head>
  <body>
    <header class="exam-toolbar">
      <div class="l">
        <span class="title"><%= @exam.title %></span>
        <span class="badge"><span class="dot"></span>Ready to print</span>
        <span class="mono">
          <%= pluralize(@exam.exam_questions.size, 'question') %>
          <% if @exam.duration_minutes.present? %> · <%= @exam.duration_minutes %> min<% end %>
          <% if @exam.seed.present? %> · seed <b><%= @exam.seed.to_s(16).rjust(4, '0') %></b><% end %>
        </span>
      </div>
      <nav class="r">
        <%= link_to 'Marking scheme', marking_scheme_exam_path(@exam), class: 'btn' %>
        <%= link_to 'Regenerate', new_exam_path, class: 'btn' %>
        <%= link_to 'Download PDF', exam_path(@exam, format: :pdf), class: 'btn primary' %>
      </nav>
    </header>

    <%= yield %>
  </body>
</html>
