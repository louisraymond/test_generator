<%#
  Wave 3 — Canvas inspector rail.
  Per-type content panel on top (registry-dispatched) + common Content /
  Marking / Metadata form underneath. The type-specific block surfaces the
  interactions the paper can't show (reseed, pin list, line index),
  while the common form stays for stem / answer / metadata edits.
%>
<% descriptor = QuestionTypes.for(question.question_type) %>
<turbo-frame id="rail-body" data-controller="rail">
  <header class="rail__header">
    <span class="rail__eyebrow">
      <%= descriptor&.icon %> <%= descriptor&.label || question.question_type.humanize %>
    </span>
    <span class="rail__qref">
      Q<%= exam_question.position %>
      · <%= question.points %> <%= 'mark'.pluralize(question.points) %>
    </span>
    <button class="rail__collapse" data-action="rail#collapse" aria-label="Collapse inspector" type="button">⟩</button>
  </header>

  <div class="rail-tabs" role="tablist">
    <button type="button" class="rail-tab is-active" role="tab" data-action="click->rail#switch" data-rail-tab="content" aria-selected="true">Content</button>
    <button type="button" class="rail-tab" role="tab" data-action="click->rail#switch" data-rail-tab="marking" aria-selected="false">Marking</button>
    <button type="button" class="rail-tab" role="tab" data-action="click->rail#switch" data-rail-tab="metadata" aria-selected="false">Metadata</button>
  </div>

  <%= form_with model: question, url: question_path(question), method: :patch,
                data: { controller: 'rail-form', 'rail-form-exam-id-value': exam_question.exam_id } do |f| %>

    <section class="rail-panel is-active" data-rail-panel="content">
      <%# Per-type content summary + type-specific controls %>
      <%= render 'exam_questions/rail_content',
                 question: question, exam_question: exam_question, descriptor: descriptor %>

      <div class="rail-field">
        <label class="rail-field__label" for="question_content">Stem</label>
        <%= f.text_area :content, id: 'question_content', rows: 6, class: 'rail-input',
                        placeholder: 'Question stem (Markdown + KaTeX supported)' %>
      </div>

      <div class="rail-field">
        <label class="rail-field__label" for="question_answer">Answer</label>
        <%= f.text_area :answer, id: 'question_answer', rows: 4, class: 'rail-input',
                        placeholder: 'Free-text answer (fallback if no structured marking steps)' %>
      </div>
    </section>

    <section class="rail-panel" data-rail-panel="marking">
      <div class="rail-field">
        <label class="rail-field__label">Credit events</label>
        <p class="rail-hint">
          <%= pluralize(question.marking_steps.count, 'marking step') %> recorded.
          <% if question.marking_steps.any? %>
            <ul class="rail-mark-list">
              <% question.marking_steps.ordered.each do |step| %>
                <li class="rail-mark-list__row">
                  <span class="mark mark--<%= step.kind %>"><%= step.pill_label %></span>
                  <span class="rail-mark-list__text"><%= truncate(step.text.to_s, length: 110) %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </p>
      </div>

      <div class="rail-field">
        <label class="rail-field__label" for="question_marker_notes">Notes to marker</label>
        <%= f.text_area :marker_notes, id: 'question_marker_notes', rows: 3, class: 'rail-input' %>
      </div>
    </section>

    <section class="rail-panel" data-rail-panel="metadata">
      <div class="rail-field">
        <label class="rail-field__label" for="question_bloom_level">Bloom level</label>
        <%= f.select :bloom_level, Question::BLOOM_LEVELS.map { |b| [b.capitalize, b] },
                     { include_blank: '—' }, class: 'rail-input', id: 'question_bloom_level' %>
      </div>

      <div class="rail-field">
        <label class="rail-field__label" for="question_points">Marks</label>
        <%= f.number_field :points, id: 'question_points', min: 1, max: 100, class: 'rail-input' %>
      </div>

      <div class="rail-field">
        <label class="rail-field__label" for="question_answer_label">Answer label</label>
        <%= f.text_field :answer_label, id: 'question_answer_label', class: 'rail-input', placeholder: 'e.g. θ =' %>
      </div>

      <div class="rail-field">
        <label class="rail-field__label" for="question_unit">Unit</label>
        <%= f.text_field :unit, id: 'question_unit', class: 'rail-input', placeholder: 'e.g. °, m/s' %>
      </div>

      <div class="rail-field">
        <label class="rail-field__label">Topic</label>
        <p class="rail-hint"><%= question.topic&.name %></p>
      </div>
    </section>

    <footer class="rail-footer">
      <%= link_to 'Open full editor ↗', edit_question_path(question),
                  target: '_blank', class: 'rail-link' %>
      <%= f.submit 'Save', class: 'rail-btn' %>
    </footer>
  <% end %>
</turbo-frame>
